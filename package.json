{
  "name": "handoff-app",
  "version": "2.0.0",
  "description": "Automated documentation toolchain for building client side documentation from figma",
  "author ": {
    "name": "Convertiv",
    "email": "handoff@convertiv.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Convertiv/handoff-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Convertiv/handoff-app.git"
  },
  "keywords": [
    "design",
    "documentation",
    "figma",
    "handoff"
  ],
  "homepage": "https://www.handoff.com/",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "handoff-app": "./dist/cli.js"
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=20.9.0"
  },
  "scripts": {
    "prepare": "npm run build",
    "start": "node ./dist/cli.js start",
    "dev": "node ./dist/cli.js dev",
    "build": "tsc && tsc-alias -p tsconfig.json && node scripts/fix-dist-esm-imports.mjs",
    "build:static": "node ./dist/cli.js build:app",
    "build:dynamic": "node ./dist/cli.js build:app --mode dynamic",
    "build:vercel": "node ./dist/cli.js build:app --mode vercel",
    "prepare-runtime": "node ./dist/cli.js prepare-runtime",
    "fetch": "node ./dist/cli.js fetch",
    "lint": "cd src/app && npx eslint app components lib",
    "release": "np --any-branch",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "tsx --test test/path-contract.test.ts test/ephemeral-runtime.test.ts",
    "playwright:install": "npx playwright install chromium",
    "db:generate": "drizzle-kit generate",
    "db:generate:sqlite": "drizzle-kit generate --config drizzle-sqlite.config.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/app/lib/db/seed.ts",
    "db:bootstrap": "tsx src/app/lib/db/bootstrap-admin.ts",
    "design-asset-worker": "tsx src/app/lib/server/design-asset-worker.ts"
  },
  "prettier": {
    "printWidth": 140,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "tailwindConfig": "./tailwind.config.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@clack/prompts": "^0.7.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.2.8",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.3",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/typography": "^0.5.16",
    "@types/lodash": "^4.14.185",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-scroll": "^1.8.6",
    "@types/react-syntax-highlighter": "^15.5.7",
    "@types/refractor": "^3.0.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "archiver": "^5.3.1",
    "better-sqlite3": "^11.10.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-spawn": "^7.0.3",
    "dotenv": "^16.0.3",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.0.2",
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "handoff-core": "^0.2.0",
    "handoff-docgen": "^0.1.0",
    "html-react-parser": "^5.2.5",
    "lodash": "^4.17.21",
    "lucide-react": "^0.518.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.4",
    "node-html-parser": "^6.1.4",
    "playwright-core": "^1.59.1",
    "postcss": "^8.4.16",
    "postgres": "^3.4.9",
    "prettier": "^3.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-element-to-jsx-string": "^17.0.1",
    "react-is": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-scroll": "^1.8.9",
    "react-syntax-highlighter": "^16.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.0",
    "sass": "^1.85.0",
    "satori": "^0.26.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.1.14",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "vite": "^8.0.0",
    "ws": "^8.18.3",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.11.18",
    "@types/yargs": "^17.0.33",
    "drizzle-kit": "^0.31.10",
    "np": "^10.2.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "sass-embedded": "^1.89.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "5.6.3"
  }
}
