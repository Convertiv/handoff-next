# Handoff app (Next) — copy to `.env` and adjust for local / deploy.

# `static` (default export) or `dynamic` (Postgres-backed editing + auth)
HANDOFF_MODE=dynamic

DATABASE_URL=postgresql://user:pass@localhost:5432/handoff

# NextAuth / Auth.js — required for sessions in dynamic mode
AUTH_SECRET=generate-a-long-random-string

# Optional OAuth (when set, NextAuth uses database sessions + these providers)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Public site URL for password-reset and invite links in emails
HANDOFF_APP_URL=http://localhost:3000

# Resend — when unset, invite/reset emails are logged only (no send)
RESEND_API_KEY=
# Optional verified sender (defaults to Resend onboarding domain in dev)
# RESEND_FROM=Handoff <notifications@yourdomain.com>

# First-run bootstrap: if the `user` table is empty, seed creates one admin (run `npm run db:seed`)
HANDOFF_ADMIN_EMAIL=admin@example.com
HANDOFF_ADMIN_PASSWORD=change-me-on-first-login
