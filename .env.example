# Handoff app (Next) — copy to `.env` and adjust.

# --- Database ---
# Omit DATABASE_URL for local solo dev: Handoff uses embedded SQLite at `.handoff/local.db` (auto-created).
# Set DATABASE_URL to Postgres for team auth, invites, and production.
# DATABASE_URL=postgresql://user:pass@localhost:5432/handoff

# NextAuth / Auth.js — required when using Postgres (`DATABASE_URL`)
AUTH_SECRET=generate-a-long-random-string

# Optional OAuth (when set, NextAuth uses database sessions + these providers)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_FIGMA_ID=
# AUTH_FIGMA_SECRET=

# --- Optional: push/pull declarations to a remote Handoff (Postgres) instance ---
# HANDOFF_CLOUD_URL=https://your-team-handoff.example.com
# HANDOFF_CLOUD_TOKEN=shared-secret-matching-remote_HANDOFF_SYNC_SECRET
# Legacy names (still supported): HANDOFF_SYNC_URL, HANDOFF_SYNC_SECRET
#
# When HANDOFF_AI_API_KEY is unset, HANDOFF_CLOUD_URL + HANDOFF_CLOUD_TOKEN also
# enable AI features (design workbench, pattern wizard, component generation) by
# proxying OpenAI calls to that remote server. The cloud must set HANDOFF_SYNC_SECRET
# to the same value as HANDOFF_CLOUD_TOKEN and have HANDOFF_AI_API_KEY configured.

# Figma source file to fetch from when running GUI/worker fetch.
# Required for non-interactive token fetch jobs.
# HANDOFF_FIGMA_PROJECT_ID=

# Public site URL for password-reset and invite links in emails
HANDOFF_APP_URL=http://localhost:3000

# Resend — when unset, invite/reset emails are logged only (no send)
RESEND_API_KEY=
# Optional verified sender (defaults to Resend onboarding domain in dev)
# RESEND_FROM=Handoff <notifications@yourdomain.com>

# First-run bootstrap: if the `user` table is empty, seed creates one admin (run `npm run db:seed`)
HANDOFF_ADMIN_EMAIL=admin@example.com
HANDOFF_ADMIN_PASSWORD=change-me-on-first-login

# OpenAI key on this server. Omit when using cloud AI proxy (HANDOFF_CLOUD_* without local key).
HANDOFF_AI_API_KEY=
# OpenAI model for pattern generation and vision tasks (default: gpt-4o-mini)
# Recommended: gpt-4.1 (best instruction-following + vision)
# Alternatives: gpt-4o, gpt-4.1-mini
HANDOFF_AI_MODEL=gpt-4.1
# Chat completion timeout (ms); prevents design-to-component from hanging indefinitely on a stalled OpenAI request (default 180000).
HANDOFF_AI_REQUEST_TIMEOUT_MS=180000

# --- Design-to-component + reference materials ---
# Base URL the Next server uses to load built preview HTML in Playwright (background `after()` jobs have no request host).
# Must match where the app is reachable from the same machine (default in code: http://127.0.0.1:$PORT).
HANDOFF_APP_INTERNAL_ORIGIN=http://127.0.0.1:3000

# Max time (ms) to poll DB for a Vite component_build_job to finish after spawning the worker (default 300000 = 5 min).
HANDOFF_COMPONENT_BUILD_WAIT_MS=300000

# Max time (ms) for one `handoff.component()` call inside the worker child process (default 120000 = 2 min; allowlisted in component-builder spawn env).
HANDOFF_COMPONENT_WORKER_TIMEOUT_MS=120000

# Models for design-to-component (optional; fallbacks use gpt-4o / gpt-4.1-mini).
# For best visual fidelity, use a strong coding + vision model.
# Recommended: claude-sonnet-4-20250514 or gpt-4o (requires HANDOFF_AI_API_KEY with that provider)
HANDOFF_COMPONENT_GEN_MODEL=gpt-4o
HANDOFF_VISION_MODEL=gpt-4o
HANDOFF_REFERENCE_MODEL=gpt-4.1-mini

# Vision compare pass threshold 0–1 (default 0.78).
HANDOFF_COMPONENT_VISUAL_THRESHOLD=0.78
